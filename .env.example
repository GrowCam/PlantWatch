# Kopiere diese Datei nach ".env" und trage deine persönlichen Werte ein.
TELEGRAM_BOT_TOKEN=dein-telegram-bot-token
TELEGRAM_CHAT_ID=123456789
MQTT_HOST=raspberrypi.local
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
PUMP_TOPIC=zigbee2mqtt/pump/set
HEATER_TOPIC=zigbee2mqtt/heizung_keller/set
MQTT_TRANSPORT=tcp
MQTT_WS_PATH=/
WATER_SENSOR_TOPIC=zigbee2mqtt/Wassermelder_keller
WATER_GUARD_ENABLED=1
HEATER_CONTROL_ENABLED=1
HEATER_DAY_TARGET_C=19
HEATER_NIGHT_TARGET_C=23
HEATER_ON_BELOW_OFFSET_C=0.4
HEATER_OFF_ABOVE_OFFSET_C=0.3
HEATER_MIN_ON_SECONDS=900
HEATER_MIN_OFF_SECONDS=600
HEATER_SENSOR_MAX_AGE_SECONDS=2700
HEATER_CONTROL_INTERVAL_SECONDS=60
HEATER_SENSOR_MEDIAN_SAMPLES=3
HEATER_DEBUG_NOTIFY=0
