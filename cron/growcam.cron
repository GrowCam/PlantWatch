# Timelapse-Prüfung alle 5 Minuten, tatsächliches Capture über App-Settings gesteuert
*/5 * * * * __INSTALL_DIR__/.venv/bin/python __INSTALL_DIR__/cam.py --timelapse >> __INSTALL_DIR__/cam_timelapse.log 2>&1

# Bewässerungs-Check einmal täglich (16:45)
45 16 * * * __INSTALL_DIR__/.venv/bin/python __INSTALL_DIR__/check_watering.py >> __INSTALL_DIR__/check_watering.log 2>&1
